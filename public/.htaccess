Options -MultiViews
RewriteEngine On

# Never rewrite paths that already contain the placeholder
RewriteRule __dynamic__ - [L]

# Dynamic route rewrites:
# RewriteCond !-f and !-d ensures real files/directories (like Next.js
# internal files __next.* or named pages like /create) are never rewritten.

# Workers: /dashboard/business/workers/{workerId}/edit
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^dashboard/business/workers/([^/]+)/edit/?$ /dashboard/business/workers/__dynamic__/edit/ [L]

# Workers: /dashboard/business/workers/{workerId}
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^dashboard/business/workers/([^/]+)/?$ /dashboard/business/workers/__dynamic__/ [L]

# Products catalog: /dashboard/business/products/catalog/{productId}/edit
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^dashboard/business/products/catalog/([^/]+)/edit/?$ /dashboard/business/products/catalog/__dynamic__/edit/ [L]

# Products: /dashboard/business/products/{businessProductId}/edit
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^dashboard/business/products/([^/]+)/edit/?$ /dashboard/business/products/__dynamic__/edit/ [L]

# Providers: /dashboard/business/providers/{providerId}/edit
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^dashboard/business/providers/([^/]+)/edit/?$ /dashboard/business/providers/__dynamic__/edit/ [L]

# Expenses: /dashboard/business/expenses/{expenseId}/edit
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^dashboard/business/expenses/([^/]+)/edit/?$ /dashboard/business/expenses/__dynamic__/edit/ [L]

# Reset password: /reset-password/{token}
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^reset-password/([^/]+)/?$ /reset-password/__dynamic__/ [L]

# SPA fallback: serve index.html for any other non-existing path
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]
